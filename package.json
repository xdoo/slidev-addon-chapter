{
  "name": "slidev-addon-chapters",
  "version": "0.1.1",
  "description": "Explicit, theme-independent chapter semantics for Slidev",
  "author": "Claus Straube",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xdoo/slidev-addon-chapter.git"
  },
  "homepage": "https://github.com/xdoo/slidev-addon-chapter#readme",
  "bugs": {
    "url": "https://github.com/xdoo/slidev-addon-chapter/issues"
  },
  "keywords": [
    "slidev",
    "slidev-addon",
    "chapters",
    "subchapters",
    "presentation"
  ],
  "packageManager": "npm@11.17.0",
  "files": [
    "components",
    "composables",
    "src",
    "README.md",
    "LICENSE"
  ],
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./composables": {
      "types": "./composables/index.ts",
      "import": "./composables/index.ts"
    }
  },
  "engines": {
    "node": ">=20.19.0",
    "slidev": ">=52.18.0"
  },
  "peerDependencies": {
    "@slidev/client": ">=52.18.0",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@slidev/cli": "52.18.0",
    "@slidev/client": "52.18.0",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "@types/node": "latest",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "latest",
    "jsdom": "latest",
    "playwright-chromium": "^1.61.1",
    "typescript": "^5.9.3",
    "vitest": "latest",
    "vue": "latest",
    "vue-tsc": "latest"
  },
  "scripts": {
    "dev": "slidev playground/slides.md --open=false",
    "test": "node --test tests/*.node.mjs && node scripts/check-pure-test-imports.mjs && vitest run",
    "test:e2e": "node scripts/e2e.mjs",
    "typecheck": "vue-tsc --noEmit",
    "build": "slidev build playground/slides.md --out dist",
    "verify:fixture": "node scripts/verify-packed-package.mjs",
    "export:pdf": "slidev export playground/slides.md --format pdf --output dist/chapters.pdf",
    "export:pptx": "slidev export playground/slides.md --format pptx --output dist/chapters.pptx"
  }
}
